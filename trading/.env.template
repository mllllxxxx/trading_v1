TELEGRAM_TRADER_STATUS_URL=http://127.0.0.1:8000/api/trader/status

# -------- Locale --------------------------------------------------------
LC_ALL=C.UTF-8
PYTHONIOENCODING=utf-8
PYTHONUTF8=1
