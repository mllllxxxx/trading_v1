# =======================================================================
# Vibe-Trading configuration
# Generated: 2026-06-21 for solo trader, Vietnam, OKX, DeepSeek
# Location: C:\Users\minhl\.vibe-trading\.env (user home, NOT project)
# IMPORTANT: do NOT commit this file with real keys to git
# =======================================================================

# -------- LLM provider (LangChain) ------------------------------------
# Source: cli/onboard.py line 64-68 confirms deepseek-v4-pro is a real model
LANGCHAIN_PROVIDER=deepseek
LANGCHAIN_MODEL_NAME=deepseek-v4-pro
DEEPSEEK_API_KEY=PASTE_YOUR_DEEPSEEK_KEY_HERE

# Alternative cheaper model for batch backtest research (line 68):
# DEEPSEEK_MODEL=deepseek-v4-flash

# -------- OKX broker (TESTNET / paper trading) -------------------------
# Get testnet keys at: https://www.okx.com/vi/demo-trading
# After login: Profile -> API -> Create API key
# Permissions: Read + Trade, NO Withdraw
# These get consumed by `vibe-trading connector configure okx-paper-trade`
OKX_API_KEY=PASTE_YOUR_OKX_KEY_HERE
OKX_API_SECRET=PASTE_YOUR_OKX_SECRET_HERE
OKX_PASSPHRASE=PASTE_YOUR_OKX_PASSPHRASE_HERE
OKX_TESTNET=true
OKX_SANDBOX=true

# -------- Data sources (free tier) -------------------------------------
# Alpha Vantage free: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# -------- Vibe-Trading behaviour ---------------------------------------
VIBE_TRADING_DATA_CACHE=true

# -------- Demo signal execution ----------------------------------------
# paper = broker-free journal simulation
# okx_demo = OKX demo/testnet only; refuses live-like env and missing keys
SIGNAL_EXECUTION_ADAPTER=okx_demo
OKX_DEMO_ADAPTER_DRY_RUN=false
REQUIRE_LLM_DECISION=true
ENABLE_RULES_ONLY_FALLBACK=false
AUTO_MAX_POSITIONS=10
AUTO_DAILY_LOSS_CAP_PCT=0.03
AUTO_DAILY_LLM_COST_CAP_USD=0.20
AUTO_DAILY_LLM_CALL_CAP=160
AUTO_HOURLY_LLM_CALL_CAP=16
AUTO_HOURLY_LLM_CALL_CAP_PER_SOURCE=4
AUTO_LLM_OVER_CAP_BEHAVIOR=fail_closed
AUTO_LLM_PROMPT_MODE=compact
AUTO_LLM_MAX_TOKENS=2400
AUTO_LLM_REVIEW_MAX_TOKENS=500
AUTO_DECISION_POLICY=adaptive_hybrid_v1
AUTO_ADAPTIVE_CONTROLLER_ENABLED=true
AUTO_SHADOW_EVALUATION_ENABLED=true
AUTO_SHADOW_MAX_HOLD_BARS=192
AUTO_SHADOW_FEE_BPS_PER_LEG=5
AUTO_SHADOW_SLIPPAGE_BPS=2
AUTO_SHADOW_MAX_SYMBOLS_PER_CYCLE=12
AUTO_SHADOW_MAX_PENDING=2000
AUTO_SHADOW_CANDLE_LIMIT=300
TRADER_ADAPTIVE_EVALUATION_TTL_S=60
AUTO_LLM_TICKET_PARSE_ATTEMPTS=2
AUTO_PENDING_ENTRY_TTL_S=3600
AUTO_LEGACY_SCHEDULER_ENABLED=false

# Small-capital demo profile. These are non-secret runtime controls.
TRADING_RISK_PROFILE=demo_team_tournament_200
TRADING_EQUITY_CAP_USD=200
AUTO_CAPITAL=200
FUTURES_RISK_PCT=0.05
FUTURES_MAX_POSITION_PCT=0.60
FUTURES_MAX_MARGIN_PCT=0.20
FUTURES_MAX_LEVERAGE=3
STRATEGY_TEAM_MAX_OPEN_POSITIONS=1
STRATEGY_MAX_CONFIRMED_CANDLE_AGE_S=1080
AUTO_DEMO_FEE_RATE=0.0005
BERKSHIRE_LLM_HOLD_COOLDOWN_MINUTES=60
BERKSHIRE_LLM_ERROR_COOLDOWN_MINUTES=15
STRATEGY_TEAM_IDS=berkshire,momentum,mean_reversion,volatility_breakout

# Scheduled Berkshire crypto scan loop
BERKSHIRE_SIGNAL_SCHEDULER_ENABLED=true
BERKSHIRE_SIGNAL_INTERVAL_S=900
BERKSHIRE_SIGNAL_LIMIT=50
BERKSHIRE_SIGNAL_MAX_PROMOTIONS=10
BERKSHIRE_SIGNAL_MAX_LLM_ATTEMPTS_PER_CYCLE=3
BERKSHIRE_LLM_MIN_CONFIDENCE=0.72
BERKSHIRE_LLM_MIN_SCORE=70
BERKSHIRE_LLM_SYMBOL_COOLDOWN_MINUTES=240
BERKSHIRE_LLM_CACHE_TTL_S=21600
BERKSHIRE_SIGNAL_EQUITY_USD=200

# -------- Telegram private cockpit ------------------------------------
# Secrets/identifiers belong only in the real ~/.vibe-trading/.env file.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Recommended explicit operator ID. For backward-compatible private chats,
# the runtime may use TELEGRAM_CHAT_ID when this is empty.
TELEGRAM_USER_ID=
TELEGRAM_DASHBOARD_ENABLED=true
TELEGRAM_DASHBOARD_REFRESH_S=60
TELEGRAM_DASHBOARD_HEARTBEAT_S=300
TELEGRAM_DASHBOARD_COALESCE_S=5
